# Copy to .env and fill in your values. Every field has a working default
# in config/settings.py — only set what you actually need to change.

# ── App ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Set to "true" to use synthetic candles instead of real market data.
# Safe for initial deploy; flip to "false" once broker credentials are set.
MOCK_MODE=false

# ── Auth ─────────────────────────────────────────────────────────────────
# Protects /trade/submit, /portfolio/close, /strategy/select, and
# /analyze?execute_if_signal=true. Leave blank to disable (local dev only).
API_AUTH_TOKEN=

# Comma-separated origins allowed for cross-origin requests.
# Use * to allow all (fine for a private trading app).
CORS_ALLOWED_ORIGINS=*

# Required only for the Vercel cron endpoint (/cron/tick). Leave blank
# if not using Vercel.
CRON_SECRET=

# ── LLM providers ────────────────────────────────────────────────────────
# Set at least one. LLM_PROVIDER=auto prefers Anthropic; falls back to
# Gemini; falls back to keyword-heuristic sentiment if neither is set.
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Brokers ──────────────────────────────────────────────────────────────
# Priority: Dhan → Alpaca → Binance (default) → PaperBroker (mock)

# Dhan — Indian markets (NSE/BSE equities, F&O).
# Get credentials from https://dhanhq.co/docs/v2/
# DHAN_DEFAULT_EXCHANGE options: NSE_EQ | BSE_EQ | NSE_FNO | IDX_I
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_DEFAULT_EXCHANGE=NSE_EQ

# Alpaca — US equities & crypto (paper trading URL shown).
# https://app.alpaca.markets/paper-trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Binance — crypto spot (public endpoints work without keys).
BINANCE_API_KEY=
BINANCE_SECRET=

# ── Infrastructure ───────────────────────────────────────────────────────
# PostgreSQL — for Render, copy the "External Database URL" from the DB page.
DATABASE_URL=postgresql://user:password@host:5432/trading_os

# Redis — optional; news sentiment cache falls back to in-memory without it.
REDIS_URL=redis://localhost:6379

# Kafka — optional; event bus falls back to in-memory without it.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Optional extras ──────────────────────────────────────────────────────
NEWS_API_KEY=
OPENAI_API_KEY=
POLYGON_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Background live-suggestions loop ─────────────────────────────────────
# Disabled automatically on Vercel (cron replaces it there).
ENABLE_LIVE_SUGGESTIONS=true
# Comma-separated asset symbols for the active broker:
#   Dhan:   RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK
#   Alpaca: AAPL,MSFT,NVDA,SPY,BTCUSD
#   Binance: BTCUSDT,ETHUSDT,SOLUSDT
LIVE_SUGGESTIONS_ASSETS=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK
LIVE_SUGGESTIONS_INTERVAL_SEC=30.0

# ── Fine-tuning (optional overrides) ─────────────────────────────────────
PRIMARY_LLM_MODEL=claude-sonnet-4-6
FALLBACK_LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1
SLIPPAGE_TOLERANCE_BPS=5.0
SMART_ORDER_MIN_SIZE_USD=10000.0

# Sub-model overrides use double-underscore delimiter:
# RISK__MAX_POSITION_PCT=0.05
# RISK__MAX_PORTFOLIO_EXPOSURE=0.40
# CONSENSUS__MIN_AVG_CONFIDENCE=68.0
# AGENT_WEIGHTS__TECHNICAL=0.30
