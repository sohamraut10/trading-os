# Copy to .env and fill in what you need. Every field has a working
# default in config/settings.py, so you only need to set what you're
# actually changing — this file lists everything for reference.

# ── App ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# MOCK_MODE bypasses the real Binance/Alpaca data feed with synthetic
# candles (core/data/market_data.py MockProvider) — not a pydantic Settings
# field, read directly from the environment in api/main.py's AppState.
MOCK_MODE=false

# ── Auth ─────────────────────────────────────────────────────────────────
# Required to protect /trade/submit, /portfolio/reset, /portfolio/close,
# /strategy/select, and /analyze with execute_if_signal=true. Leave blank
# to disable (fine for local dev, not for anything internet-facing).
API_AUTH_TOKEN=

# Comma-separated. Only matters for cross-origin requests (e.g. a dashboard
# dev server on a different port); same-origin deployments aren't affected.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,http://localhost:3000

# Required to enable GET /cron/tick (the Vercel-Cron-driven replacement for
# live_suggestions_loop on serverless). Vercel auto-sends
# `Authorization: Bearer $CRON_SECRET` when this env var is set on the
# project — set the same value here to match. Endpoint is disabled (503)
# if left blank.
CRON_SECRET=

# ── API keys (all optional — features degrade gracefully without them) ──
# SentimentAgent and TradeJournal use whichever of ANTHROPIC_API_KEY /
# GEMINI_API_KEY is configured (LLM_PROVIDER=auto prefers Anthropic if both
# are set); falls back to keyword-heuristic sentiment scoring / no journal
# analysis if neither is usable.
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=AIzaSyCWKIlP6-UcllI7ip_SpIXnJ0Fzdxe40s4
GEMINI_MODEL=gemini-3.1-pro
OPENAI_API_KEY=
ALPACA_API_KEY=PKDHQGDABU6R5BMUL7UPQG4XHQ
ALPACA_SECRET_KEY=C1gVmApjW4UWt3YyeVo5Drm4SSeXRannNpWZdrJ7CVyr
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Dhan broker — Indian markets (NSE/BSE equities, F&O, currency, commodity).
# When set, DhanBroker takes priority over Alpaca. Requires `pip install dhanhq`.
# Get your client_id and access_token from https://dhanhq.co/docs/v2/
# DHAN_DEFAULT_EXCHANGE: NSE_EQ | BSE_EQ | NSE_FNO | NSE_CURRENCY | MCX_COMM | IDX_I
DHAN_CLIENT_ID=1100474794
DHAN_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzUxMiJ9.eyJpc3MiOiJkaGFuIiwicGFydG5lcklkIjoiIiwiZXhwIjoxNzgzOTIwODc1LCJpYXQiOjE3ODM4MzQ0NzUsInRva2VuQ29uc3VtZXJUeXBlIjoiU0VMRiIsIndlYmhvb2tVcmwiOiIiLCJkaGFuQ2xpZW50SWQiOiIxMTAwNDc0Nzk0In0.GrZzw9hABI15V0JdO9o-H1YHHrAp2LPaMzVBjQrsNtsz7Bzrex8wdg_kaccd53hGpk3p4q4d_92YFXGK-y3nfQ
DHAN_DEFAULT_EXCHANGE=NSE_EQ
BINANCE_API_KEY=
BINANCE_SECRET=
POLYGON_API_KEY=
NEWS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Infrastructure ───────────────────────────────────────────────────────
# Local Docker Compose default. For Render: use the External Database URL
# from the dashboard. For Fly.io: set automatically by `fly postgres attach`.
DATABASE_URL=postgresql://trading:lmOLbNQUAp2XM5P839ZjPg7F1qFZRfHx@dpg-d99b96v7f7vs73a4v1ig-a/trading_os_2cdd

# Optional — NewsCache falls back to in-memory if unreachable.
REDIS_URL=redis://localhost:6379

# Optional — the event bus falls back to an in-memory bus if unreachable.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── LLM ──────────────────────────────────────────────────────────────────
PRIMARY_LLM_MODEL=claude-sonnet-4-6
FALLBACK_LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ── Execution ────────────────────────────────────────────────────────────
SLIPPAGE_TOLERANCE_BPS=5.0
SMART_ORDER_MIN_SIZE_USD=10000.0

# ── Background live-suggestions loop ────────────────────────────────────
# Disabled automatically when VERCEL=1 is set (Vercel sets this itself) —
# GET /cron/tick replaces it there instead.
ENABLE_LIVE_SUGGESTIONS=true
LIVE_SUGGESTIONS_ASSETS=BTCUSDT,ETHUSDT,SOLUSDT,EURUSD,GBPUSD,USDJPY
LIVE_SUGGESTIONS_INTERVAL_SEC=15.0

# ── Nested config (agent_weights / risk / consensus) ────────────────────
# These are sub-models with their own defaults in config/settings.py.
# Override individual fields with the double-underscore delimiter if needed,
# e.g.:
# RISK__MAX_POSITION_PCT=0.05
# RISK__MAX_PORTFOLIO_EXPOSURE=0.40
# CONSENSUS__MIN_AVG_CONFIDENCE=68.0
# AGENT_WEIGHTS__TECHNICAL=0.30
