# Two-stage build: Vite → nginx
# Used by docker-compose.prod.yml; the API container also embeds the build
# for single-container deployments (Render/Fly). Here we serve it standalone
# behind Caddy so the API and frontend can scale and deploy independently.

# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app

# Install dependencies first (better layer caching)
COPY dashboard/package*.json ./
RUN npm ci --prefer-offline

# Copy source and build
COPY dashboard/ ./
# VITE_ env vars baked in at build time; pass with --build-arg if needed
ARG VITE_API_URL=https://api.example.com
ARG VITE_WS_URL=wss://api.example.com
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_WS_URL=$VITE_WS_URL
RUN npm run build

# ── Stage 2: serve ────────────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS production
WORKDIR /usr/share/nginx/html

# Remove default content
RUN rm -rf ./*

# Copy built assets
COPY --from=build /app/dist ./

# Custom nginx config for SPA routing (all 404s → index.html)
RUN cat > /etc/nginx/conf.d/default.conf <<'EOF'
server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # SPA routing: serve index.html for all unknown paths so React Router works
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Static asset cache headers
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Health probe for docker healthcheck and Caddy upstream check
    location /nginx-health {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    # Security: hide nginx version
    server_tokens off;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript
               text/xml application/xml application/xml+rss text/javascript
               image/svg+xml;
    gzip_min_length 1024;
    gzip_vary on;
}
EOF

EXPOSE 80

HEALTHCHECK --interval=20s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1:80/nginx-health || exit 1
