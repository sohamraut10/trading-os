# Caddyfile — HTTP-only reverse proxy for Trading OS
#
# Architecture: Internet → Cloudflare Tunnel → cloudflared → caddy:80
# Cloudflare terminates TLS; Caddy routes plain HTTP internally.
# All virtual hosts live in a single :80 block matched by Host header.
#
# Rate limiting is handled at the Cloudflare layer (free tier includes it).
# Env var required: DOMAIN  (e.g. example.com)

{
    log {
        output stdout
        format console
        level  INFO
    }
    servers {
        timeouts {
            read_body   10s
            read_header 10s
            write        0s   # 0 = no write timeout, required for WebSocket/SSE
            idle         5m
        }
    }
    # Disable automatic HTTPS — Cloudflare handles TLS
    auto_https off
}

:80 {
    # ── Health probe (docker healthcheck + monitoring) ──────────────────────
    handle /caddy-health {
        respond "ok" 200
    }

    # ── Security headers (applied to all responses) ─────────────────────────
    header {
        X-Content-Type-Options      "nosniff"
        Referrer-Policy             "strict-origin-when-cross-origin"
        -Server
    }

    # ── Frontend — trade.DOMAIN ─────────────────────────────────────────────
    @frontend host trade.{$DOMAIN}
    handle @frontend {
        encode gzip zstd
        header {
            X-Frame-Options         "DENY"
            Permissions-Policy      "geolocation=(), microphone=(), camera=()"
            Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://s3.tradingview.com https://s3.tradingview.com; style-src 'self' 'unsafe-inline' https://s3.tradingview.com; img-src 'self' data: https:; connect-src 'self' https://api.{$DOMAIN} wss://api.{$DOMAIN} https://*.tradingview.com wss://*.tradingview.com; font-src 'self' data: https://s3.tradingview.com; frame-src https://*.tradingview.com; worker-src blob:; frame-ancestors 'none';"
        }
        reverse_proxy frontend:80 {
            health_uri      /nginx-health
            health_interval 30s
            health_timeout  5s
        }
    }

    # ── API — api.DOMAIN ────────────────────────────────────────────────────
    @api host api.{$DOMAIN}
    handle @api {
        encode gzip zstd

        # WebSocket upgrade passthrough
        @websocket {
            header Connection *Upgrade*
            header Upgrade    websocket
            path   /ws/*
        }
        handle @websocket {
            reverse_proxy api:8000 {
                transport http {
                    dial_timeout            5s
                    response_header_timeout 0s
                    read_timeout            0s
                    write_timeout           0s
                }
                header_up Host            {host}
                header_up X-Real-IP       {remote_host}
                header_up X-Forwarded-For {remote_host}
                header_up Connection      "Upgrade"
                header_up Upgrade         "websocket"
            }
        }

        handle {
            reverse_proxy api:8000 {
                transport http {
                    dial_timeout            5s
                    response_header_timeout 60s
                }
                header_up Host            {host}
                header_up X-Real-IP       {remote_host}
                header_up X-Forwarded-For {remote_host}
                health_uri      /health
                health_interval 30s
                health_timeout  5s
            }
        }
    }

    # ── Grafana — grafana.DOMAIN ─────────────────────────────────────────────
    @grafana host grafana.{$DOMAIN}
    handle @grafana {
        encode gzip

        @grafana_ws {
            header Connection *Upgrade*
            header Upgrade    websocket
        }
        handle @grafana_ws {
            reverse_proxy grafana:3000 {
                header_up Connection "Upgrade"
                header_up Upgrade    "websocket"
            }
        }
        handle {
            reverse_proxy grafana:3000 {
                health_uri      /api/health
                health_interval 30s
                health_timeout  5s
            }
        }
    }

    # ── Catch-all: reject unknown hosts ─────────────────────────────────────
    handle {
        respond "Not found" 404
    }
}
