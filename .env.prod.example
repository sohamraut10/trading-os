# .env.prod.example — Production environment variables for Trading OS
# Copy this to .env.prod and fill in every value before first launch.
# NEVER commit .env.prod to git (it is in .gitignore).
#
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ── Domain ────────────────────────────────────────────────────────────────────
# Your Cloudflare-managed domain. Subdomains created:
#   trade.<DOMAIN>    → frontend dashboard
#   api.<DOMAIN>      → FastAPI backend
#   grafana.<DOMAIN>  → Grafana monitoring
DOMAIN=example.com

# Frontend build-time URLs (baked into the Vite bundle)
# These must match your actual subdomain configuration above.
VITE_API_URL=https://api.example.com
VITE_WS_URL=wss://api.example.com

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get this by running: cloudflared tunnel token <TUNNEL_NAME>
# See setup guide step 3 for how to create the tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Strong random password. Generate one: openssl rand -base64 32
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
# No password needed for the Docker-internal Redis; it's not reachable
# from outside. Add requirepass here if you want auth.
# REDIS_PASSWORD=

# ── API Security ──────────────────────────────────────────────────────────────
# Protects state-changing endpoints (trade submission, portfolio reset).
# Generate: openssl rand -hex 32
API_AUTH_TOKEN=

# Secret for the /cron/tick endpoint (Vercel Cron compatible).
# Generate: openssl rand -hex 32
CRON_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the FastAPI CORS middleware.
CORS_ALLOWED_ORIGINS=https://trade.example.com

# ── LLM / AI ─────────────────────────────────────────────────────────────────
# At least one of ANTHROPIC_API_KEY or GEMINI_API_KEY must be set.
# LLM_PROVIDER selects which one the sentiment and journal features use.
# Values: anthropic | gemini
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
# Optional: override the default Claude model
# ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── Market Data ───────────────────────────────────────────────────────────────
# Binance (crypto, default data source when no Dhan/Alpaca key is set)
BINANCE_API_KEY=
BINANCE_SECRET=

# News API (https://newsapi.org) — used for sentiment analysis
NEWS_API_KEY=

# ── Broker — choose one ───────────────────────────────────────────────────────
# Priority: Dhan (if set) → Alpaca (if set) → PaperBroker (default)

# Dhan (Indian markets — NSE/BSE)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
# DHAN_DEFAULT_EXCHANGE=NSE_EQ

# Alpaca (US stocks & crypto paper/live trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper trading URL (default). Change to https://api.alpaca.markets for live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Alerts ───────────────────────────────────────────────────────────────────
# Telegram bot — get token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Strong password for Grafana admin. Generate: openssl rand -base64 20
GRAFANA_ADMIN_PASSWORD=

# ── Live Suggestions Loop ─────────────────────────────────────────────────────
# Set to true to enable the background loop that runs consensus cycles.
ENABLE_LIVE_SUGGESTIONS=true
# Comma-separated asset symbols to scan
LIVE_SUGGESTIONS_ASSETS=BTCUSDT,ETHUSDT
# Seconds between cycles per asset
LIVE_SUGGESTIONS_INTERVAL_SEC=60

# ── Mock Mode ─────────────────────────────────────────────────────────────────
# Set to true to use a random-price MockProvider instead of live data.
# Useful for testing the stack without real API keys.
MOCK_MODE=false

# ── Watchtower notifications (optional) ───────────────────────────────────────
# Shoutrrr URL for Watchtower to send update notifications.
# Examples:
#   telegram://TOKEN@telegram?chats=CHAT_ID
#   slack://TOKEN@CHANNEL
# Leave blank to disable.
WATCHTOWER_NOTIFICATIONS=
WATCHTOWER_NOTIFICATION_URL=

# ── Kafka (optional) ──────────────────────────────────────────────────────────
# Leave blank — the event bus falls back to in-memory mode without Kafka.
KAFKA_BOOTSTRAP_SERVERS=
